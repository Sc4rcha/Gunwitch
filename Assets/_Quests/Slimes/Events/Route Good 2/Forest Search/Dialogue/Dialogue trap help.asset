  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 227a819172f1b7040ab509841b30715c, type: 3}
  m_Name: Dialogue trap help
  m_EditorClassIdentifier: Assembly-CSharp::SODialogue
  Characters: []
  Nodes:
  - IndexCharacterRight: 0
    IndexCharacterLeft: 0
    IndexCharacterFocus: 0
    IndexExpression: 0
    IndexEmotion: 0
    Text: You stop the guard before she steps on the trap.
  - IndexCharacterRight: 0
    IndexCharacterLeft: 0
    IndexCharacterFocus: 0
    IndexExpression: 0
    IndexEmotion: 0
    Text: She thinks you are from the bandits and tries to attack you.
  - IndexCharacterRight: 0
    IndexCharacterLeft: 0
    IndexCharacterFocus: 0
    IndexExpression: 0
    IndexEmotion: 0
    Text: 'You stop her and tell her to shut the fuck up. You are also here to find
      the bandits. You want them dead. '
  - IndexCharacterRight: 0
    IndexCharacterLeft: 0
    IndexCharacterFocus: 0
    IndexExpression: 0
    IndexEmotion: 0
    Text: The guard doesn't believe you but you show her that you are from the guild.
  - IndexCharacterRight: 0
    IndexCharacterLeft: 0
    IndexCharacterFocus: 0
    IndexExpression: 0
    IndexEmotion: 0
    Text: You tell her to leave and call for her friends. She can clean up your mess
      after you're done with the bandits
  - IndexCharacterRight: 0
    IndexCharacterLeft: 0
    IndexCharacterFocus: 0
    IndexExpression: 0
    IndexEmotion: 0
    Text: She is not interested and tells you she will stop them herself.
  - IndexCharacterRight: 0
    IndexCharacterLeft: 0
    IndexCharacterFocus: 0
    IndexExpression: 0
    IndexEmotion: 0
    Text: You go your separate ways.
